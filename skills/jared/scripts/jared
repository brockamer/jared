#!/usr/bin/env python3
"""jared — unified CLI for common Jared (GitHub Projects v2) operations."""

from __future__ import annotations

import argparse
import json
import sys
import time
from pathlib import Path
from typing import Any

# Make sibling lib/ importable regardless of cwd. mypy can't follow the
# sys.path manipulation, so the import itself gets a type-ignore; the real
# types are still enforced inside lib.board.
sys.path.insert(0, str(Path(__file__).resolve().parent))

from lib.board import (  # type: ignore[import-not-found]  # noqa: E402
    Board,
    FieldNotFound,
    ItemNotFound,
    OptionNotFound,
)


STUB_SUBCOMMANDS = [
    "file",
    "comment",
    "blocked-by",
]
ALL_SUBCOMMANDS = [*STUB_SUBCOMMANDS, "get-item", "summary", "set", "move", "close"]


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="jared",
        description="jared — GitHub Projects v2 board operations.",
    )
    parser.add_argument(
        "--board",
        default="docs/project-board.md",
        help="Path to project-board.md (default: docs/project-board.md)",
    )
    sub = parser.add_subparsers(
        dest="cmd",
        required=True,
        metavar="{" + ",".join(ALL_SUBCOMMANDS) + "}",
    )

    for name in STUB_SUBCOMMANDS:
        p = sub.add_parser(name, help=f"(stub) {name}")
        p.set_defaults(func=_stub_factory(name))

    get_item = sub.add_parser(
        "get-item",
        help="Return JSON: issue number, item-id, and project field values.",
    )
    get_item.add_argument("issue_number", type=int)
    get_item.set_defaults(func=_cmd_get_item)

    summary = sub.add_parser("summary", help="One-screen board status summary.")
    summary.set_defaults(func=_cmd_summary)

    set_p = sub.add_parser("set", help="Set a single-select field on an issue.")
    set_p.add_argument("issue_number", type=int)
    set_p.add_argument("field_name", help='e.g. "Priority" or "Status"')
    set_p.add_argument("value", help='e.g. "High" or "In Progress"')
    set_p.set_defaults(func=_cmd_set)

    move = sub.add_parser(
        "move",
        help="Move an issue to a new Status (Backlog/Up Next/In Progress/Blocked/Done).",
    )
    move.add_argument("issue_number", type=int)
    move.add_argument("status", help='e.g. "In Progress"')
    move.set_defaults(func=_cmd_move)

    close_p = sub.add_parser(
        "close",
        help="Close issue + verify/force auto-move to Done.",
    )
    close_p.add_argument("issue_number", type=int)
    close_p.set_defaults(func=_cmd_close)

    return parser


def _stub_factory(name: str):  # type: ignore[no-untyped-def]
    def run(_args: argparse.Namespace) -> int:
        print(f"{name}: not implemented yet", file=sys.stderr)
        return 2

    return run


def _cmd_get_item(args: argparse.Namespace) -> int:
    board = Board.from_path(Path(args.board))
    try:
        item_id = board.find_item_id(args.issue_number)
    except ItemNotFound as e:
        print(str(e), file=sys.stderr)
        return 1

    data = board.run_gh([
        "project", "item-list",
        str(board.project_number),
        "--owner", board.owner,
        "--limit", "500",
        "--format", "json",
    ])
    empty: dict[str, Any] = {}
    match: dict[str, Any] = next(
        (
            item for item in data.get("items", [])
            if (item.get("content") or {}).get("number") == args.issue_number
        ),
        empty,
    )
    excluded = {"id", "content"}
    output = {
        "issue_number": args.issue_number,
        "item_id": item_id,
        "status": match.get("status"),
        "priority": match.get("priority"),
        "fields": {k: v for k, v in match.items() if k not in excluded},
    }
    print(json.dumps(output, indent=2))
    return 0


def _cmd_move(args: argparse.Namespace) -> int:
    # Shortcut: set Status=<status>. Synthesize the attrs _cmd_set reads.
    args.field_name = "Status"
    args.value = args.status
    return _cmd_set(args)


_CLOSE_VERIFY_ATTEMPTS = 3
_CLOSE_VERIFY_SLEEP_SECS = 1.0


def _cmd_close(args: argparse.Namespace) -> int:
    board = Board.from_path(Path(args.board))

    board.run_gh([
        "issue", "close",
        str(args.issue_number),
        "--repo", board.repo,
    ])

    # GitHub auto-moves closed issues to Done via its board workflow, but
    # the propagation is eventually-consistent. Poll a few times before
    # falling back to an explicit Status=Done via _cmd_set.
    for _ in range(_CLOSE_VERIFY_ATTEMPTS):
        data = board.run_gh([
            "project", "item-list",
            str(board.project_number),
            "--owner", board.owner,
            "--limit", "500",
            "--format", "json",
        ])
        match: dict[str, Any] | None = next(
            (
                i for i in data.get("items", [])
                if (i.get("content") or {}).get("number") == args.issue_number
            ),
            None,
        )
        if match and match.get("status") == "Done":
            print(f"OK: closed #{args.issue_number}, board auto-moved to Done")
            return 0
        time.sleep(_CLOSE_VERIFY_SLEEP_SECS)

    args.field_name = "Status"
    args.value = "Done"
    rc = _cmd_set(args)
    if rc == 0:
        print(f"OK: closed #{args.issue_number} (manual move to Done)")
    return rc


def _cmd_set(args: argparse.Namespace) -> int:
    board = Board.from_path(Path(args.board))
    try:
        item_id = board.find_item_id(args.issue_number)
        field_id = board.field_id(args.field_name)
        option_id = board.option_id(args.field_name, args.value)
    except (ItemNotFound, FieldNotFound, OptionNotFound) as e:
        print(str(e), file=sys.stderr)
        return 1

    board.run_gh([
        "project", "item-edit",
        "--project-id", board.project_id,
        "--id", item_id,
        "--field-id", field_id,
        "--single-select-option-id", option_id,
    ])
    print(f"OK: set {args.field_name}={args.value} on issue #{args.issue_number}")
    return 0


def _cmd_summary(args: argparse.Namespace) -> int:
    board = Board.from_path(Path(args.board))
    data = board.run_gh([
        "project", "item-list",
        str(board.project_number),
        "--owner", board.owner,
        "--limit", "500",
        "--format", "json",
    ])
    items: list[dict[str, Any]] = data.get("items", [])

    def by_status(status: str) -> list[dict[str, Any]]:
        return [i for i in items if i.get("status") == status]

    def render_item(item: dict[str, Any], *, with_priority: bool = True) -> str:
        content = item.get("content") or {}
        num = content.get("number")
        title = content.get("title", "")
        if with_priority:
            prio = item.get("priority") or "-"
            return f"  #{num} [{prio}] {title}"
        return f"  #{num} {title}"

    in_progress = by_status("In Progress")
    up_next_all = by_status("Up Next")
    up_next = up_next_all[:3]
    blocked = by_status("Blocked")

    print(f"Board: {board.project_url}")
    print()
    print(f"In Progress ({len(in_progress)}):")
    for it in in_progress:
        print(render_item(it))
    print()
    print(f"Up Next (top 3 of {len(up_next_all)}):")
    for it in up_next:
        print(render_item(it))
    if blocked:
        print()
        print(f"Blocked ({len(blocked)}):")
        for it in blocked:
            print(render_item(it, with_priority=False))
    return 0


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    result: int = args.func(args)
    return result


if __name__ == "__main__":
    sys.exit(main())
